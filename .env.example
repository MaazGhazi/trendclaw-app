# =============================================================================
# TrendClaw Environment Variables
# Copy this to .env and fill in your keys
# =============================================================================

# === LLM (required) ===
# GPT-4o for daily digest + weekly deep dive (best analysis)
# GPT-4o-mini for quick pulse (fast, runs 96x/day)
OPENAI_API_KEY=sk-your-openai-key-here

# === Search (required) ===
# Brave Search API — powers web_search for context and gap-filling
# Sign up: https://brave.com/search/api/
# Paid plan recommended (~$5/mo for 20K queries)
BRAVE_API_KEY=your-brave-search-key-here

# === Data Source APIs (optional but recommended) ===
# YouTube Data API — trending videos with view counts
# Get key: https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3)
# Free tier: 10,000 units/day
YOUTUBE_API_KEY=your-youtube-api-key-here

# NewsAPI — top headlines from 150K+ news sources
# Sign up: https://newsapi.org/register
# Free tier: 100 requests/day
NEWSAPI_KEY=your-newsapi-key-here

# === Proxy for browser scraping (optional) ===
# Residential proxy for scraping Google Trends, TikTok, etc.
# Without this, browser scraping may get blocked on some sites.
# ScraperAPI: https://www.scraperapi.com/ (~$29/mo)
# Bright Data: https://brightdata.com/ (~$30/mo residential)
# PROXY_URL=http://user:pass@proxy.scraperapi.com:8001

# === Gateway (required) ===
OPENCLAW_GATEWAY_TOKEN=your-random-gateway-token-here
OPENCLAW_HOOKS_TOKEN=your-random-hooks-token-here
TRENDCLAW_WEBHOOK_URL=http://localhost:3000/api/trends

# === Scraper output (auto-set in deploy script) ===
SCRAPER_OUTPUT_DIR=$HOME/.openclaw/workspace/scraper-data
